# Neon database connection string
DATABASE_URL=postgres://user:pass@host/dbname

# Secret for signing JWT sessions — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

# Admin credentials (add as many as you need: ADMIN2_USERNAME, ADMIN2_PASSWORD, etc.)
ADMIN1_USERNAME=admin
ADMIN1_PASSWORD=changeme
